---
// DotField.astro
// Props with defaults matching the original React component
const {
  dotRadius = 1.5,
  dotSpacing = 14,
  cursorRadius = 500,
  cursorForce = 0.1,
  bulgeOnly = true,
  bulgeStrength = 67,
  glowRadius = 160,
  sparkle = false,
  waveAmplitude = 0,
  gradientFrom = 'rgba(168, 85, 247, 0.35)',
  gradientTo = 'rgba(180, 151, 207, 0.25)',
  glowColor = '#120F17',
} = Astro.props;
---

<div class="dot-field-container">
  <canvas class="dot-field-canvas"></canvas>
  <svg class="dot-field-svg" aria-hidden="true">
    <defs>
      <radialGradient id="dot-glow-grad">
        <stop offset="0%" stop-color={glowColor} />
        <stop offset="100%" stop-color="transparent" />
      </radialGradient>
    </defs>
    <circle
      class="dot-glow-circle"
      cx="-9999" cy="-9999"
      r={glowRadius}
      fill="url(#dot-glow-grad)"
      style="opacity:0"
    />
  </svg>
</div>

<style>
  .dot-field-container {
    z-index: -1;
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
  }

  .dot-field-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 200%;
    overflow-x: scroll;
  }

  .dot-field-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>

<script define:vars={{
  dotRadius,
  dotSpacing,
  cursorRadius,
  cursorForce,
  bulgeOnly,
  bulgeStrength,
  sparkle,
  waveAmplitude,
  gradientFrom,
  gradientTo,
}}>
  (function () {
    const TWO_PI = Math.PI * 2;

    const container = document.querySelector('.dot-field-container');
    const canvas    = container.querySelector('.dot-field-canvas');
    const glowEl    = container.querySelector('.dot-glow-circle');
    const ctx       = canvas.getContext('2d', { alpha: true });
    const dpr       = Math.min(window.devicePixelRatio || 1, 2);

    // ── State ────────────────────────────────────────────────────────────
    let dots        = [];
    let frameCount  = 0;
    let rafId       = null;
    let resizeTimer = null;
    let glowOpacity = 0;
    let engagement  = 0;
    let size        = { w: 0, h: 0, offsetX: 0, offsetY: 0 };
    const mouse     = { x: -9999, y: -9999, prevX: -9999, prevY: -9999, speed: 0 };

    // ── Resize ───────────────────────────────────────────────────────────
  function doResize() {
  const w = window.innerWidth;
  const h = window.innerHeight;

  canvas.width  = w * dpr;
  canvas.height = h * dpr;
  canvas.style.width  = w + 'px';
  canvas.style.height = h + 'px';
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

  size = { w, h, offsetX: 0, offsetY: 0 };
  buildDots(w, h);
}

// Use clientX/clientY — coordinates relative to viewport, not page
function onMouseMove(e) {
  mouse.x = e.clientX;
  mouse.y = e.clientY;
}

    function onResize() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(doResize, 100);
    }

    // ── Dot grid ─────────────────────────────────────────────────────────
    function buildDots(w, h) {
      const step = dotRadius + dotSpacing;
      const cols = Math.floor(w / step);
      const rows = Math.floor(h / step);
      const padX = (w % step) / 2;
      const padY = (h % step) / 2;

      dots = [];
      for (let row = 0; row < rows; row++) {
        for (let col = 0; col < cols; col++) {
          const ax = padX + col * step + step / 2;
          const ay = padY + row * step + step / 2;
          dots.push({ ax, ay, sx: ax, sy: ay, vx: 0, vy: 0, x: ax, y: ay });
        }
      }
    }

    // ── Mouse ────────────────────────────────────────────────────────────
    function onMouseMove(e) {
      mouse.x = e.pageX - size.offsetX;
      mouse.y = e.pageY - size.offsetY;
    }

    // Mouse speed sampled on interval (matches original 20ms)
    const speedInterval = setInterval(() => {
      const dx   = mouse.prevX - mouse.x;
      const dy   = mouse.prevY - mouse.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      mouse.speed += (dist - mouse.speed) * 0.5;
      if (mouse.speed < 0.001) mouse.speed = 0;
      mouse.prevX = mouse.x;
      mouse.prevY = mouse.y;
    }, 20);

    // ── Render loop ──────────────────────────────────────────────────────
    function tick() {
      frameCount++;
      const { w, h } = size;
      const len = dots.length;
      const t   = frameCount * 0.02;

      // Engagement (cursor activity → opacity of glow + physics scale)
      const targetEng = Math.min(mouse.speed / 5, 1);
      engagement += (targetEng - engagement) * 0.06;
      if (engagement < 0.001) engagement = 0;

      glowOpacity += (engagement - glowOpacity) * 0.08;

      // Update SVG glow circle
      glowEl.setAttribute('cx', mouse.x);
      glowEl.setAttribute('cy', mouse.y);
      glowEl.style.opacity = glowOpacity;

      // Draw
      ctx.clearRect(0, 0, w, h);

      const grad = ctx.createLinearGradient(0, 0, w, h);
      grad.addColorStop(0, gradientFrom);
      grad.addColorStop(1, gradientTo);
      ctx.fillStyle = grad;

      const crSq = cursorRadius * cursorRadius;
      const rad  = dotRadius / 2;

      ctx.beginPath();

      for (let i = 0; i < len; i++) {
        const d  = dots[i];
        const dx = mouse.x - d.ax;
        const dy = mouse.y - d.ay;
        const distSq = dx * dx + dy * dy;

        if (distSq < crSq && engagement > 0.01) {
          const dist  = Math.sqrt(distSq);
          if (bulgeOnly) {
            const tt   = 1 - dist / cursorRadius;
            const push = tt * tt * bulgeStrength * engagement;
            const ang  = Math.atan2(dy, dx);
            d.sx += (d.ax - Math.cos(ang) * push - d.sx) * 0.15;
            d.sy += (d.ay - Math.sin(ang) * push - d.sy) * 0.15;
          } else {
            const ang  = Math.atan2(dy, dx);
            const move = (500 / dist) * (mouse.speed * cursorForce);
            d.vx += Math.cos(ang) * -move;
            d.vy += Math.sin(ang) * -move;
          }
        } else if (bulgeOnly) {
          d.sx += (d.ax - d.sx) * 0.1;
          d.sy += (d.ay - d.sy) * 0.1;
        }

        if (!bulgeOnly) {
          d.vx *= 0.9;
          d.vy *= 0.9;
          d.x   = d.ax + d.vx;
          d.y   = d.ay + d.vy;
          d.sx += (d.x - d.sx) * 0.1;
          d.sy += (d.y - d.sy) * 0.1;
        }

        let drawX = d.sx;
        let drawY = d.sy;

        if (waveAmplitude > 0) {
          drawY += Math.sin(d.ax * 0.03 + t) * waveAmplitude;
          drawX += Math.cos(d.ay * 0.03 + t * 0.7) * waveAmplitude * 0.5;
        }

        if (sparkle) {
          const hash = (((i * 2654435761) ^ (frameCount >> 3)) >>> 0) % 100;
          const r    = hash < 3 ? rad * 1.8 : rad;
          ctx.moveTo(drawX + r, drawY);
          ctx.arc(drawX, drawY, r, 0, TWO_PI);
        } else {
          ctx.moveTo(drawX + rad, drawY);
          ctx.arc(drawX, drawY, rad, 0, TWO_PI);
        }
      }

      ctx.fill();
      rafId = requestAnimationFrame(tick);
    }

    // ── Boot ─────────────────────────────────────────────────────────────
    // pointer-events back on for mouse tracking
    container.style.pointerEvents = 'auto';

    doResize();
    window.addEventListener('resize',    onResize);
    window.addEventListener('mousemove', onMouseMove, { passive: true });
    rafId = requestAnimationFrame(tick);

    // Cleanup on page navigation (Astro view transitions)
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(rafId);
      clearInterval(speedInterval);
      clearTimeout(resizeTimer);
      window.removeEventListener('resize',    onResize);
      window.removeEventListener('mousemove', onMouseMove);
    }, { once: true });
  })();
</script>