---
import AboutImage from '../image/ascii-art.png';
---

<div class="grid-shell">

  <div class="row row--hero">
    <div class="cell cell--intro">
      <p class="eyebrow">NLP / DLWP / Mech Interp</p>
      <h1>Vishnu<br />Kadam</h1>
      <p class="lede">
        BS-MS graduate, IISER Pune. Deep learning from theory to
        application — now going deep on mechanistic interpretability.
      </p>
    </div>
    <div class="cell cell--portrait">
      <img src={AboutImage.src} alt="Vishnu Kadam" />
    </div>
  </div>

  <div class="row row--split">
    <div class="cell cell--now">
      <p class="label">Now</p>
      <p>
        Investigating mechanistic interpretability techniques on AI
        weather models — uncovering what these models actually learn
        internally.
      </p>
    </div>
    <div class="cell cell--stack">
      <p class="label">Stack</p>
      <div class="tags">
        <span>Mech Interp</span>
        <span>DL</span>
        <span>NLP</span>
        <span>Weather</span>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="cell cell--pub">
      <p class="label">Publication / 2026</p>
      <p class="pub-title">
        CurvePotGCN — predicting protein–protein interactions using
        surface curvature and electrostatic potential as node features
      </p>
      <a href="https://link.springer.com/article/10.1007/s12039-025-02459-7">
        read paper →
      </a>
    </div>
  </div>

  <div class="row row--projects">
    <div class="cell">
      <p class="label">01 / Thesis</p>
      <h3>Weather prediction</h3>
      <p>
        SFNO-based model, fine-tuned and benchmarked for regional
        forecasting. Now extending with mechanistic interpretability.
      </p>
    </div>
    <div class="cell">
      <p class="label">02 / Research</p>
      <h3>Protein interaction</h3>
      <p>
        End-to-end GNN pipeline — dataset creation, architecture,
        training, benchmarking. My first publication.
      </p>
    </div>
    <div class="cell">
      <p class="label">03 / Project</p>
      <h3>Diffusion models</h3>
      <p>
        Annealed Langevin dynamics, implemented from scratch with
        extensive visualisations.
      </p>
    </div>
  </div>

</div>

<style>
  .grid-shell {
    border: 1px solid var(--color-border);
  }

  .row {
    display: grid;
    border-bottom: 1px solid var(--color-border);
  }

  .row:last-child {
    border-bottom: none;
  }

  .cell {
    padding: 2rem;
    border-right: 1px solid var(--color-border);
  }

  .cell:last-child {
    border-right: none;
  }

  /* ── Hero row ── */
  .row--hero {
    grid-template-columns: 2fr 1fr;
  }

  .cell--intro {
    display: flex;
    flex-direction: column;
    justify-content: center;
   
  }

  .eyebrow {
    font-family: 'Courier New', monospace;
    font-size: .72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1rem;
  }

  .cell--intro h1 {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    font-weight: 500;
    line-height: 1;
    color: var(--color-ink);
    margin: 0 0 1.25rem;
  }

  .lede {
    font-size: 1.1rem;
    line-height: 1.65;
    color: var(--color-muted);
    margin: 0;
    max-width: 42ch;
  }

  /* ── Portrait cell — strictly contained ── */
  .cell--portrait {
    padding: 0;
    min-height: 320px;
    overflow: hidden;
    background: var(--color-surface-soft);
  }

  .cell--portrait img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  /* ── Now / Stack row ── */
  .row--split {
    grid-template-columns: 2fr 1fr;
  }

  .label {
    /* font-family: 'Courier New', monospace; */
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.75rem;
  }

  .cell--now p:last-child,
  .cell--pub p,
  .cell--projects p {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-text);
    margin: 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tags span {
    font-family: 'Courier New', monospace;
    font-size: 0.7rem;
    padding: 3px 9px;
    border: 1px solid var(--color-border-strong);
    /* color: var(--color-muted); */
  }

  /* ── Publication row ── */
  .cell--pub {
    /* background: var(--color-surface); */
  }

  .pub-title {
    font-family: Georgia, serif;
    font-size: 1.1rem;
    line-height: 1.45;
    color: var(--color-ink);
    margin: 0 0 0.6rem;
    max-width: 65ch;
  }

  .cell--pub a {
    font-family: 'Courier New', monospace;
    font-size: 0.78rem;
    color: var(--color-accent);
    text-decoration: none;
  }

  /* ── Projects row ── */
  .row--projects {
    grid-template-columns: repeat(3, 1fr);
     background: var(--color-surface);
  }

  .row--projects h3 {
    font-family: Georgia, serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-ink);
    margin: 0 0 0.75rem;
    background-color: blur(4px);
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .row--hero,
    .row--split,
    .row--projects {
      grid-template-columns: 1fr;
    }

    .cell {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }

    .cell:last-child {
      border-bottom: none;
    }

    .cell--portrait {
      min-height: 240px;
    }
  }
</style>