---
import BaseLayout from '../layouts/BaseLayout.astro'
const allPosts = Object.values(import.meta.glob('./posts/*.md', { eager: true }));
const pageTitle = "";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="blog-shell">

    <div class="blog-head">
      <p class="eyebrow">Writing</p>
      <h1>Blog</h1>
    </div>

    <div class="post-grid">
      {allPosts.map((post: any) => (
        <a href={post.url} class="post-card">
          <div class="post-img">
            <img
              src={post.frontmatter.image || 'https://via.placeholder.com/800x500?text=Blog+Post'}
              alt={post.frontmatter.title}
            />
          </div>
          <div class="post-body">
            {post.frontmatter.date && (
              <p class="post-date">
                {new Date(post.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
            )}
            <h2 class="post-title">{post.frontmatter.title}</h2>
            {post.frontmatter.description && (
              <p class="post-desc">{post.frontmatter.description}</p>
            )}
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .blog-shell {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .blog-head {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
  }

  .eyebrow {
    font-family: 'Courier New', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 0.6rem;
  }

  .blog-head h1 {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 500;
    color: var(--color-ink);
    margin: 0;
    line-height: 1;
  }

  /* ── Grid: hairline borders via shared background trick ── */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
  }

  .post-card:hover {
    background: var(--color-surface-soft);
  }

  .post-card:hover .post-title {
    color: var(--color-accent-strong);
  }

  .post-img {
    width: 100%;
    height: 200px;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .post-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-body {
    padding: 1.5rem;
  }

  .post-date {
    font-family: 'Courier New', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 0.6rem;
  }

  .post-title {
    font-family: Georgia, serif;
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-ink);
    line-height: 1.35;
    margin: 0 0 0.5rem;
    transition: color 0.15s ease;
  }

  .post-desc {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
  }

  @media (max-width: 700px) {
    .post-grid {
      grid-template-columns: 1fr;
    }

    .blog-shell {
      padding: 1.5rem 1rem 3rem;
    }
  }
</style>